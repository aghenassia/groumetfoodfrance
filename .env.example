# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@localhost:5432/crm_db
DATABASE_URL_SYNC=postgresql://crm_user:crm_password@localhost:5432/crm_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Sage 100 (ODBC) ---
SAGE_ODBC_DRIVER={ODBC Driver 17 for SQL Server}
SAGE_ODBC_SERVER=100.x.x.x
SAGE_ODBC_DATABASE=nom_base_sage
SAGE_ODBC_USER=crm_readonly
SAGE_ODBC_PASSWORD=change-me

# --- Ringover ---
RINGOVER_API_KEY=change-me
RINGOVER_WEBHOOK_SECRET=change-me
RINGOVER_BASE_URL=https://public-api.ringover.com/v2

# --- OpenAI (Phase 2) ---
OPENAI_API_KEY=change-me

# --- JWT ---
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_DAYS=7
